<!-- Dragonfly, 6 simple shapes: 1 head, 1 body, 4 wings. Wings are thick asymmetric blades (rounded
     broad outer end, narrow inner) that stop short of the body; carrot body (wide thorax -> tail);
     separate head. White, over violet. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 4 wings: thick blades, rounded outer tip, narrow inner end held off the body -->
    <group android:pivotX="42" android:pivotY="40" android:rotation="18">
        <path android:fillColor="#FFFFFFFF"
            android:pathData="M42,40 C35,34 24,34 17,37 C13,38.5 13,41.5 17,43 C24,46 35,46 42,40 Z" />
    </group>
    <group android:pivotX="42" android:pivotY="49" android:rotation="-18">
        <path android:fillColor="#FFFFFFFF"
            android:pathData="M42,49 C35,43 24,43 17,46 C13,47.5 13,50.5 17,52 C24,55 35,55 42,49 Z" />
    </group>
    <group android:pivotX="66" android:pivotY="40" android:rotation="-18">
        <path android:fillColor="#FFFFFFFF"
            android:pathData="M66,40 C73,34 84,34 91,37 C95,38.5 95,41.5 91,43 C84,46 73,46 66,40 Z" />
    </group>
    <group android:pivotX="66" android:pivotY="49" android:rotation="18">
        <path android:fillColor="#FFFFFFFF"
            android:pathData="M66,49 C73,43 84,43 91,46 C95,47.5 95,50.5 91,52 C84,55 73,55 66,49 Z" />
    </group>

    <!-- body: carrot — wide thorax at the top tapering to a pointed tail -->
    <path android:fillColor="#FFFFFFFF"
        android:pathData="M54,32.5 C58.5,32.5 62,36 62,41 C61.5,56 57.5,70 55,82 C54.5,84.5 53.5,84.5 53,82 C50.5,70 46.5,56 46,41 C46,36 49.5,32.5 54,32.5 Z" />

    <!-- head: separate circle just above the thorax -->
    <path android:fillColor="#FFFFFFFF"
        android:pathData="M47.5,25 a6.5,6.5 0 1,0 13,0 a6.5,6.5 0 1,0 -13,0" />
</vector>
