# Dragonfly ID — identity provider (BROKER.md Phase 2). Copy to .env and fill in.

# Postgres (asyncpg). Use 127.0.0.1, not localhost (IPv6-first resolution stalls fresh conns).
DATABASE_URL=postgresql+asyncpg://id:id@127.0.0.1:5432/dragonfly_id

# Signs the server's own session/refresh state (NOT the OIDC tokens — those use OIDC_PRIVATE_KEY).
SECRET_KEY=change-me

# OIDC issuer identity. ISSUER is the public base URL clients see as `iss`.
ISSUER=http://localhost:8010
# RS256 private key (PEM) that signs OIDC tokens; the public half is published at JWKS. Generate a
# stable one for deploy: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# Leave unset locally to auto-generate a throwaway key on boot.
# OIDC_PRIVATE_KEY=

# Single-user suite: set an invite code so registration stays closed after your account exists.
# REGISTRATION_INVITE_CODE=

# Deploy hardening (enable behind HTTPS + trusted proxy).
# TRUST_PROXY=true
# HSTS_ENABLED=true
# DOCS_ENABLED=false
