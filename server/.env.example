# Dragonfly ID — identity provider (BROKER.md Phase 2). Copy to .env and fill in.

# Postgres (asyncpg). Compose overrides this to reach the db service; for a local run against
# the compose db use 127.0.0.1:5435 (this service's host port).
DATABASE_URL=postgresql+asyncpg://dragonfly_id:dragonfly_id@127.0.0.1:5435/dragonfly_id

# Signs the browser session cookie (NOT the OIDC tokens — those use OIDC_PRIVATE_KEY).
SECRET_KEY=change-me

# OIDC issuer identity. ISSUER is the public base URL clients see as `iss` and must match what the
# app servers validate. Set to the deployed hostname (e.g. https://id.dragonflymedia.org).
ISSUER=https://id.dragonflymedia.org
# RS256 private key (PEM) that signs OIDC tokens; its public half is published at JWKS. Generate a
# STABLE key for deploy (a restart otherwise invalidates every live token):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# Paste it as a single line with \n, or mount it and read the file. Leave unset only for local dev.
# OIDC_PRIVATE_KEY=

# Single-user suite: set an invite code so registration is closed after your account exists.
# REGISTRATION_INVITE_CODE=

# Deploy hardening (enable behind HTTPS at the Cloudflare/Caddy edge).
TRUST_PROXY=true
HSTS_ENABLED=true
DOCS_ENABLED=false
